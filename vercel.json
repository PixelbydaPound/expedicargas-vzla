{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.png",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/)(?!.*\\.[a-zA-Z0-9]{2,24}$).*)",
      "destination": "/index.html"
    }
  ]
}
